{
  "name": "@andytavares/terminator",
  "version": "0.1.52",
  "description": "Extension-first AI-focused terminal emulator",
  "main": "out/main/index.js",
  "type": "module",
  "workspaces": [
    "extensions/*"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "postinstall": "electron-rebuild -w better-sqlite3",
    "build:extensions": "node scripts/build-extensions.cjs",
    "dev": "npm run build:extensions && electron-vite dev",
    "build": "npm run build:extensions && electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage --reporter=junit --outputFile=test-report.junit.xml",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "rebuild": "electron-rebuild -w better-sqlite3",
    "check-patch-coverage": "node scripts/check-patch-coverage.cjs",
    "create-extension": "node scripts/create-extension.cjs",
    "package": "electron-builder --mac --arm64 --publish never",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --ext .ts,.tsx",
      "vitest related --run"
    ],
    "*.{js,cjs}": [
      "prettier --write",
      "eslint"
    ],
    "*.{json,md,css,html,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@testing-library/dom": "^10.4.1",
    "electron-store": "^8.2.0",
    "lucide-react": "^0.475.0",
    "node-pty": "1.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "xterm": "5.3.0",
    "xterm-addon-fit": "0.8.0",
    "zod": "3.23.8",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "1.45.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "20.14.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitejs/plugin-react": "4.3.1",
    "@vitest/coverage-v8": "2.0.5",
    "electron": "30.4.0",
    "electron-builder": "24.13.3",
    "electron-vite": "2.3.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "4.6.2",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "playwright": "1.45.3",
    "prettier": "3.3.3",
    "typescript": "5.5.4",
    "vite": "5.3.5",
    "vitest": "2.0.5"
  }
}
