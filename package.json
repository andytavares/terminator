{
  "name": "@andytavares/terminator",
  "version": "0.1.68",
  "description": "Extension-first AI-focused terminal emulator",
  "main": "out/main/index.js",
  "type": "module",
  "workspaces": [
    "extensions/*"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build:extensions": "node scripts/build-extensions.cjs",
    "build:remote": "vite build --config vite.config.remote.ts",
    "dev": "npm run build:extensions && npm run build:remote && electron-vite dev",
    "build": "npm run build:extensions && npm run build:remote && electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage --reporter=verbose --reporter=junit \"--outputFile.junit=test-report.junit.xml\"",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-patch-coverage": "node scripts/check-patch-coverage.cjs",
    "create-extension": "node scripts/create-extension.cjs",
    "package": "npm run build:extensions && npm run build:remote && electron-vite build && electron-builder --mac --arm64 --publish never",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --ext .ts,.tsx",
      "vitest related --run"
    ],
    "*.{js,cjs}": [
      "prettier --write",
      "eslint"
    ],
    "*.{json,md,css,html,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@fastify/static": "9.1.3",
    "@fastify/websocket": "11.2.0",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@testing-library/dom": "^10.4.1",
    "@xterm/addon-attach": "0.12.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "bcryptjs": "2.4.3",
    "electron-store": "^8.2.0",
    "fastify": "5.8.5",
    "lucide-react": "^0.475.0",
    "node-pty": "1.2.0-beta.13",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sql.js": "^1.14.1",
    "xterm": "5.3.0",
    "xterm-addon-fit": "0.8.0",
    "zod": "3.23.8",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.19.43",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/sql.js": "^1.4.11",
    "@types/ws": "8.5.13",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitejs/plugin-react": "5.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "electron": "42.4.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "4.6.2",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "playwright": "1.61.0",
    "prettier": "3.3.3",
    "typescript": "5.5.4",
    "vite": "7.3.5",
    "vitest": "4.1.9",
    "ws": "8.21.0"
  }
}
