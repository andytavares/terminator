{
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "outDir": "out/shared",
    "rootDir": "src/shared"
  },
  "include": ["src/shared/**/*"]
}
